{
  "name": "to-diag-trace-go-root",
  "version": "1.0.0",
  "description": "Go tool to convert diagnostic traces to standard formats, built with Wails and React",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxzz/to-diag-trace-go.git"
  },
  "bugs": {
    "url": "https://github.com/maxzz/to-diag-trace-go/issues"
  },
  "homepage": "https://github.com/maxzz/to-diag-trace-go#readme",
  "author": {
    "name": "Max Zakharzhevskiy",
    "email": "maxzz@msn.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "wails dev",
    "build": "wails build --clean",
    "build:windows": "wails build --clean --platform windows/amd64",
    "build:macos": "wails build --clean --platform darwin/amd64",
    "build:macos-arm": "wails build --clean --platform darwin/arm64",
    "frontend:install": "npm --prefix frontend install",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:dev": "npm --prefix frontend run dev",
    "go:fmt": "go fmt ./...",
    "go:vet": "go vet ./...",
    "go:test": "go test ./...",
    "wails:doctor": "wails doctor"
  }
}
